#!/bin/bash

###############################################################################
# Git Hook - Pre-commit
# Régénère automatiquement le sitemap avant chaque commit
###############################################################################

echo "🔄 Vérification du sitemap..."

# Vérifier si des fichiers liés à la base de données ont été modifiés
CHANGED_FILES=$(git diff --cached --name-only)

# Vérifier si des migrations ou des données ont changé
if echo "$CHANGED_FILES" | grep -qE "(supabase/migrations|src/pages|src/components)"; then
  echo "📝 Modifications détectées, régénération du sitemap..."

  # Régénérer le sitemap
  npm run sitemap --silent

  # Ajouter le sitemap au commit
  git add public/sitemap.xml

  echo "✅ Sitemap mis à jour et ajouté au commit"
else
  echo "✓ Aucune modification nécessitant une mise à jour du sitemap"
fi

exit 0
